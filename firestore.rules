rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /parent_notifications/{notificationId} {
      allow read: if request.auth != null
        && resource.data.parentFirebaseUid == request.auth.uid;

      allow create: if request.auth != null
        && request.resource.data.parentFirebaseUid is string
        && request.resource.data.alertType in [
          'teacherAlert',
          'needsAttention',
          'distress',
          'schoolNeeded'
        ];

      allow update: if request.auth != null
        && resource.data.parentFirebaseUid == request.auth.uid
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead']);
    }

    match /parent_child_links/{linkId} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.resource.data.parentFirebaseUid == request.auth.uid
        && request.resource.data.learnerFirebaseUid is string;

      allow delete: if request.auth != null
        && resource.data.parentFirebaseUid == request.auth.uid;
    }

    match /class_enrollments_cloud/{enrollmentId} {
      allow read: if request.auth != null;

      // Learner enrolls in a class, or teacher syncs roster from local enrollment.
      allow create, update: if request.auth != null
        && request.resource.data.teacherFirebaseUid is string
        && request.resource.data.learnerFirebaseUid is string
        && request.resource.data.classCode is string
        && (
          request.resource.data.learnerFirebaseUid == request.auth.uid
          || request.resource.data.teacherFirebaseUid == request.auth.uid
        );

      allow delete: if request.auth != null
        && (
          resource.data.learnerFirebaseUid == request.auth.uid
          || resource.data.teacherFirebaseUid == request.auth.uid
        );
    }

    match /learner_profiles/{learnerUid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == learnerUid
        && request.resource.data.learnerFirebaseUid == learnerUid;
      allow delete: if false;
    }

    match /sms_alert_logs/{logId} {
      allow read: if request.auth != null
        && (
          resource.data.teacherFirebaseUid == request.auth.uid
          || resource.data.learnerFirebaseUid == request.auth.uid
        );
      allow create, update, delete: if false;
    }
  }
}
